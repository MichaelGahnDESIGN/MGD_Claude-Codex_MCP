{
  "name": "claude-codex-mcp",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "Lokaler MCP-Server für menschenlesbare Agenten-Kommunikation zwischen Codex, Claude und weiteren KI-Agenten.",
  "license": "MIT",
  "scripts": {
    "check": "npm run test && npm run smoke && npm run playwright:audit",
    "build:cli-dmg": "node --experimental-strip-types src/scripts/buildCliDmg.ts",
    "demo:agents": "node --experimental-strip-types src/scripts/twoAgentDemo.ts",
    "dev": "node --experimental-strip-types src/index.ts",
    "playwright:audit": "playwright test tests/playwright",
    "setup": "node --experimental-strip-types src/setup/index.ts",
    "smoke": "node --experimental-strip-types src/scripts/smoke.ts",
    "start": "node --experimental-strip-types src/index.ts",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.ts\""
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
